# Environnement
NODE_ENV=production
PORT=3000

# Sécurité
ADMIN_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production

# Base de données PostgreSQL (Render fournit DATABASE_URL automatiquement)
# Pour développement local: postgresql://username:password@localhost:5432/multiplication_sprint
DATABASE_URL=postgresql://localhost:5432/multiplication_sprint

# URLs
BASE_URL=https://multiplication-sprint.com
FRONTEND_URL=https://multiplication-sprint.com

# Logs
LOG_LEVEL=info
